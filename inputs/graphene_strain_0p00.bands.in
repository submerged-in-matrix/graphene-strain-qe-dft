    ibrav = 0,
    nat = 2,
    ntyp = 1,
    ecutwfc = 80.0,
    ecutrho = 640.0,
    occupations = 'smearing',
    smearing = 'mv',
    degauss = 0.02,
    nbnd = 8
/
